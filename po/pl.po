"    // borrowed as immutable.\n"
"    // let mutable_borrow = &mut point;\n"
"    // TODO ^ Try uncommenting this line\n"
msgstr ""
"// Błąd! Nie można pożyczyć `point` jako mutowalnego, ponieważ jest\n"
"    // obecnie pożyczony jako niemutowalny.\n"
"    // let mutable_borrow = &mut point;\n"
"    // TODO ^ Spróbuj odkomentować tę linię\n"

#: src/scope/borrow/alias.md:26
