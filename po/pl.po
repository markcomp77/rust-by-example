"// Instrukcje tutaj sa wykonywane, gdy skompilowany plik binarny jest "
"wywolywany.\n"
"\n"

#: src/hello.md:18
msgid "// Print text to the console.\n"
msgstr ""
"// Drukuj tekst na konsole.\n"
"\n"

