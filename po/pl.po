msgid ""
"// This code is editable, feel free to hack it!\n"
"// You can always return to the original code by clicking the \"Reset\" "
"button ->\n"
msgstr ""
"// This code is editable, feel free to hack it!\n"
"// Zawsze możesz wrócić do oryginalnego kodu, klikając przycisk „Resetuj” -"
">\n"

