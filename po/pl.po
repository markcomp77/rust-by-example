msgstr "\"Some refreshing {} is all I need.\""

#: src/error/panic.md:16 src/error/abort_unwind.md:22
#: src/error/abort_unwind.md:49 src/error/option_unwrap.md:49
msgid "\"water\""
msgstr "\"water\""

#: src/error/panic.md:18
msgid "\"still water\""
msgstr "\"still water\""

#: src/error/panic.md:22
